      <column caption='Senior Citizen Status' datatype='string' name='[Calculation_5580724860342272]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [SeniorCitizen] = 1&#10;THEN &quot;Senior Citizen&quot;&#10;ELSE &quot;Non Senior Citizen&quot;&#10;END' />
      </column>
      <column caption='Churn Flag' datatype='integer' datatype-customized='true' default-format='p0.0%' name='[Calculation_5580724860575745]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Churn] = &quot;Yes&quot;&#10;THEN 1&#10;ELSE 0&#10;END' />
      </column>
      <column caption='Churn Rate %' datatype='real' default-format='p0.0%' name='[Calculation_5580724860915714]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_5580724860575745]) / COUNT([customerID])' />
      </column>
      <column caption='Revenue Lost' datatype='real' name='[Calculation_5580724862038019]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Churn] = &quot;Yes&quot;&#10;THEN [MonthlyCharges]&#10;ELSE 0&#10;END' />
      </column>
      <column caption='Tenure group' datatype='string' name='[Calculation_5580724862226436]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [tenure] &lt;= 12 THEN &quot;0-12 Months&quot;&#10;ELSEIF [tenure] &lt;= 24 THEN &quot;13-24 Months&quot;&#10;ELSEIF [tenure] &lt;= 48 THEN &quot;25-48 Months&quot;&#10;ELSE &quot;48+ Months&quot;&#10;END' />
